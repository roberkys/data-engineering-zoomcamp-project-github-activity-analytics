# ── GCP ────────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=US
GCP_BUCKET_NAME=github-archive-your-project-id

# GCP_CREDS: base64-encoded content of your service account JSON key file.
# Generate it with:  base64 -i keys/sa_key.json  (Mac/Linux)
#                    certutil -encode keys\sa_key.json tmp.b64 && findstr /v /c:- tmp.b64  (Windows)
GCP_CREDS=<base64-encoded-service-account-json>

# ── Kestra ─────────────────────────────────────────────────────────────────────
KESTRA_USERNAME=admin@kestra.io
KESTRA_PASSWORD=Admin1234!
